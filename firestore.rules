rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for discovery data
    match /gyms/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /trainers/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // User submissions: allow create, block public reads
    match /applications/{docId} {
      allow create: if true;
      allow read: if false;
    }

    // Authenticated check-in creation only
    match /checkins/{docId} {
      allow create: if request.auth != null;
      allow read: if true;
    }

    // Partner submissions: allow create, block public reads
    match /partner_applications/{docId} {
      allow create: if true;
      allow read: if false;
    }
  }
}

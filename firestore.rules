rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Gyms & Trainers: 누구나 읽기 가능
    match /gyms/{document=**} {
      allow read: if true;
      allow write: if false; // 관리자 도구로만 업데이트
    }
    match /trainers/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Applications (상담 신청): 누구나 생성 가능, 테스트를 위해 현재는 읽기 허용
    match /applications/{docId} {
      allow create: if true;
      allow read: if true; 
    }

    // Checkins: 인증된 사용자만 생성 가능
    match /checkins/{docId} {
      allow create: if request.auth != null;
      allow read: if true; 
    }

    // Partner Applications (새로 추가)
    match /partner_applications/{docId} {
      allow create: if true;
      allow read: if true; // 운영자 확인용
    }
  }
}
